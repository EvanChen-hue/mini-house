<view class="page data-v-bf75d610"><view class="card data-v-bf75d610"><image class="cover data-v-bf75d610" src="{{imageUrl}}"></image><view class="name data-v-bf75d610">{{goods.name||'服务项目'}}</view><block wx:if="{{goods.categoryName||goods.age}}"><view class="meta data-v-bf75d610"><block wx:if="{{goods.categoryName}}"><text class="meta-tag data-v-bf75d610">{{goods.categoryName}}</text></block><block wx:if="{{goods.age}}"><text class="meta-age data-v-bf75d610">{{goods.age+"岁"}}</text></block></view></block><view class="intro data-v-bf75d610">{{goods.intro||'暂无详情介绍'}}</view><view class="price data-v-bf75d610">{{"￥"+(goods.price||'0.00')}}</view></view><view class="action-bar data-v-bf75d610"><button data-event-opts="{{[['tap',[['goReserve',['$event']]]]]}}" class="btn warn data-v-bf75d610" bindtap="__e">预约</button><button data-event-opts="{{[['tap',[['goService',['$event']]]]]}}" class="btn plain data-v-bf75d610" bindtap="__e">客服</button></view></view>